class RegisterFormData(BaseModel):
    nickname: str = ""
    city: str = ""
    age: str = ""
    height: str = ""
    weight: str = ""
    role_self: str = ""
    job: str = ""
    income: str = ""
    lifestyle_status: str = ""
    hobbies: str = ""
    current_situation: str = ""
    expectation: str = ""
    long_distance: str = ""  # 是否接受短暂异地
    body_type: str = ""  # 你认为自己的体型是
    token: str = ""  # 专属链接 token


@router.get("/register-form", response_class=HTMLResponse)
def register_form():
    """显示会员登记 H5 表单（支持 ?token=xxx 专属链接）"""
    return HTMLResponse(REGISTER_FORM_HTML)


@router.get("/check-link")
async def check_link(token: str = Query(...), db: Session = Depends(get_db)):
    """校验 token 是否有效"""
    link = db.query(RegistrationLink).filter(RegistrationLink.token == token).first()
    if not link:
        return {"valid": False, "reason": "not_found"}
    if link.status == "used":
        return {"valid": False, "reason": "already_used"}
    return {
        "valid": True,
        "customer_name": link.customer_name,
    }


def _parse_age(age_str: str) -> int | None:
    """把年龄字符串转成整数"""
    try:
        return int(age_str.strip())
    except (ValueError, AttributeError):
        return None


def _parse_int(val: str) -> int | None:
    try:
        return int(val.strip())
    except (ValueError, AttributeError):
        return None


def _save_member_profile(db: Session, data: RegisterFormData, link: RegistrationLink, result: dict) -> None:
    """保存或更新会员档案"""
    ext_userid = result.get("external_userid") or ""

    profile = None
    if ext_userid:
        profile = db.query(MemberProfile).filter(
            MemberProfile.external_userid == ext_userid
        ).first()

    if not profile:
        profile = MemberProfile()

    profile.external_userid = ext_userid if ext_userid else None
    profile.employee_userid = link.employee_userid
    profile.token = link.token
    profile.nickname = data.nickname
    profile.city = data.city
    profile.age = _parse_age(data.age)
    profile.height = _parse_int(data.height)
    profile.weight = _parse_int(data.weight)
    profile.role_self = data.role_self
    profile.body_type = data.body_type
    profile.job = data.job
    profile.income = data.income
    profile.lifestyle_status = data.lifestyle_status
    profile.hobbies = data.hobbies
    profile.current_situation = data.current_situation
    profile.expectation = data.expectation
    profile.long_distance = data.long_distance
    profile.tags_applied = json.dumps(result.get("tags_applied", []), ensure_ascii=False)

    db.add(profile)


def _form_data_dict(data: RegisterFormData) -> dict:
    return {
        "nickname": data.nickname,
        "city": data.city,
        "age": data.age,
        "height": data.height,
        "weight": data.weight,
        "role_self": data.role_self,
        "body_type": data.body_type,
        "job": data.job,
        "income": data.income,
        "lifestyle_status": data.lifestyle_status,
        "hobbies": data.hobbies,
        "current_situation": data.current_situation,
        "expectation": data.expectation,
        "long_distance": data.long_distance,
    }


def _build_wecom_customer_remark(data: RegisterFormData) -> str:
    """企微备注：蚂蚁｜广州｜29｜S|1。"""
    level = evaluate_member_level(_form_data_dict(data))
    role = str(data.role_self or "").strip() or "?"
    parts = [data.nickname, data.city, data.age]
    base = "｜".join(str(x).strip() for x in parts if str(x or "").strip())
    suffix = f"｜{level}|{role}"
    return ((base or data.nickname or "屿风会员") + suffix)[:20]


def _build_wecom_customer_description(data: RegisterFormData) -> str:
    level = evaluate_member_level(_form_data_dict(data))
    bits = [f"层级:{level}"]
    for label, value in [
        ("身高", data.height),
        ("体重", data.weight),
        ("体型", data.body_type),
        ("职业", data.job),
        ("收入", data.income),
        ("异地", data.long_distance),
        ("期待", data.expectation),
    ]:
        value = str(value or "").strip()
        if value:
            bits.append(f"{label}:{value}")
    return "；".join(bits)[:150]


def _safe(v) -> str:
    return str(v or "").strip() or "未填"


def _format_registration_data_for_employee(data: RegisterFormData, link: RegistrationLink, result: dict, matches: list[dict] | None = None) -> str:
    level = evaluate_member_level(_form_data_dict(data))
    tag_status = f"已打层级标签：层级·{level}" if result.get("auto_tagged") else result.get("tag_warning") or result.get("tag_error") or "未自动打层级标签"
    remark_text = result.get("wecom_remark") or _build_wecom_customer_remark(data)
    if result.get("remark_applied"):
        remark_status = f"已自动备注为：{remark_text}"
    else:
        remark_status = f"建议备注：{remark_text}"
        if result.get("remark_error"):
            remark_status += f"（自动备注失败：{result.get('remark_error')}）"
    lines = [
        f"📩 客户已填写专属登记表：{_safe(data.nickname or link.customer_name)}",
        "",
        f"员工原登记名：{_safe(link.customer_name)}",
        f"企微备注：{remark_status}",
        f"打标签状态：{tag_status}",
        "",
        "【客户填写资料】",
        f"昵称：{_safe(data.nickname)}",
        f"城市：{_safe(data.city)}",
        f"年龄：{_safe(data.age)}",
        f"身高/体重：{_safe(data.height)} / {_safe(data.weight)}",
        f"属性：{_safe(data.role_self)}",
        f"体型：{_safe(data.body_type)}",
        f"职业：{_safe(data.job)}",
        f"收入：{_safe(data.income)}",
        f"是否接受短暂异地：{_safe(data.long_distance)}",
        "",
        f"日常状态：{_safe(data.lifestyle_status)}",
        f"爱好习惯：{_safe(data.hobbies)}",
        f"目前状况：{_safe(data.current_situation)}",
        f"期待的你：{_safe(data.expectation)}",
    ]
    photo_urls = result.get("photo_urls") or []
    if photo_urls:
        lines.extend(["", "【近照（已压缩）】"])
        lines.extend([f"https://yufeng.team{url}" for url in photo_urls])
        if result.get("remark_pic_uploaded"):
            lines.append("已把第一张近照同步到企微客户描述图片。")
        elif result.get("remark_pic_error"):
            lines.append(f"企微描述图片同步失败：{result.get('remark_pic_error')}")
    if matches:
        lines.extend(["", "【初步匹配候选】"])
        for i, m in enumerate(matches[:5], 1):
            lines.append(f"{i}. {m.get('description', '')}")
            scores = m.get("scores") or {}
            if scores.get("total") is not None:
                lines.append(f"   匹配度：{scores.get('total')}%")
    lines.extend([
        "",
        "【建议动作】",
        "先回复客户：已认真看过他的资料，并肯定他的表达/状态；再告诉他会开始帮他筛合适的人。",
    ])
    return "\n".join(lines)[:3500]


def _registration_customer_reply(data: RegisterFormData) -> str:
    name = (data.nickname or "你").strip()
    city = (data.city or "").strip()
    age = (data.age or "").strip()
    hobbies = (data.hobbies or "").strip()
    expectation = (data.expectation or "").strip()
    current = (data.current_situation or data.lifestyle_status or "").strip()
    if expectation and len(expectation) >= 12:
        compliment = "你对期待中的关系说得挺具体的，说明不是随便填一填，而是真的有认真想过自己想要什么"
    elif hobbies and len(hobbies) >= 8:
        compliment = "你写的兴趣和生活状态还挺鲜明的，整体给人的感觉比较真实、好了解"
    elif current and len(current) >= 8:
        compliment = "你对自己目前状态的描述比较清楚，这一点对后面做匹配很有帮助"
    else:
        compliment = "你的基础信息我已经看过了，整体资料是比较清楚的"
    if city or age:
        profile_hint = f"我会先按{city or '你所在城市'}、年龄阶段和你写的期待，帮你筛一轮更合适的人。"
    else:
        profile_hint = "我会先根据你填写的状态和期待，帮你筛一轮更合适的人。"
    return f"{name}，你填的资料我已经认真看过了。{compliment}。{profile_hint}有合适的我会再单独发你确认，不会随便把你的信息公开给别人。"


REQUIRED_REGISTER_FIELDS = {
    "nickname": "昵称",
    "city": "所在城市",
    "age": "年龄",
    "height": "身高",
    "weight": "体重",
    "role_self": "属性",
    "body_type": "体型",
    "income": "收入",
    "job": "职业",
    "lifestyle_status": "日常状态",
    "hobbies": "爱好与习惯",
    "current_situation": "目前状况",
    "expectation": "期待的你",
    "long_distance": "是否接受短暂异地",
}

ALLOWED_PHOTO_TYPES = {
    "image/jpeg": ".jpg",
    "image/png": ".png",
    "image/webp": ".webp",
}
MAX_PHOTOS = 3
MAX_PHOTO_BYTES = 5 * 1024 * 1024


def _validate_register_required(data: RegisterFormData) -> None:
    missing = []
    for field, label in REQUIRED_REGISTER_FIELDS.items():
        if not str(getattr(data, field, "") or "").strip():
            missing.append(label)
    if missing:
        raise HTTPException(400, "以下项目为必填：" + "、".join(missing))


def _compress_member_photo(content: bytes) -> bytes:
    """压缩近照：自动转正方向，最长边 1600，JPEG 质量递减到约 1MB 内。"""
    try:
        img = Image.open(BytesIO(content))
        img = ImageOps.exif_transpose(img)
    except Exception as exc:
        raise HTTPException(400, "近照文件无法识别，请上传清晰的 JPG / PNG / WebP 图片") from exc
    if img.mode in ("RGBA", "LA"):
        bg = Image.new("RGB", img.size, (255, 255, 255))
        bg.paste(img, mask=img.getchannel("A"))
        img = bg
    elif img.mode != "RGB":
        img = img.convert("RGB")
    max_side = 1600
    w, h = img.size
    if max(w, h) > max_side:
        ratio = max_side / max(w, h)
        img = img.resize((int(w * ratio), int(h * ratio)), Image.LANCZOS)
    for quality in (86, 82, 78, 72, 66):
        out = BytesIO()
        img.save(out, format="JPEG", quality=quality, optimize=True, progressive=True)
        data = out.getvalue()
        if len(data) <= 1024 * 1024 or quality == 66:
            return data
    return data


async def _save_optional_photos(photos: list[UploadFile] | None, token: str = "") -> list[dict]:
    photos = [p for p in (photos or []) if p and p.filename]
    if not photos:
        return []
    if len(photos) > MAX_PHOTOS:
        raise HTTPException(400, f"近照最多上传 {MAX_PHOTOS} 张")
    upload_root = Path(settings.UPLOAD_DIR or "/data/yufeng-uploads") / "member-photos" / datetime.now().strftime("%Y%m")
    upload_root.mkdir(parents=True, exist_ok=True)
    items = []
    for idx, photo in enumerate(photos, 1):
        content_type = (photo.content_type or "").lower()
        if content_type not in ALLOWED_PHOTO_TYPES:
            raise HTTPException(400, "近照仅支持 JPG / PNG / WebP")
        content = await photo.read()
        if len(content) > MAX_PHOTO_BYTES:
            raise HTTPException(400, "单张近照不能超过 5MB")
        compressed = _compress_member_photo(content)
        prefix = token[:12] if token else uuid.uuid4().hex[:12]
        filename = f"{prefix}-{idx}-{uuid.uuid4().hex[:8]}.jpg"
        path = upload_root / filename
        path.write_bytes(compressed)
        url = f"/static/member-photos/{datetime.now().strftime('%Y%m')}/{filename}"
        items.append({"url": url, "path": str(path), "bytes": len(compressed)})
    return items


@router.post("/register-form-submit")
async def register_form_submit(
    token: str = Form(""),
    nickname: str = Form(""),
    city: str = Form(""),
    age: str = Form(""),
    height: str = Form(""),
    weight: str = Form(""),
    role_self: str = Form(""),
    body_type: str = Form(""),
    income: str = Form(""),
    job: str = Form(""),
    lifestyle_status: str = Form(""),
    hobbies: str = Form(""),
    current_situation: str = Form(""),
    expectation: str = Form(""),
    long_distance: str = Form(""),
    photos: list[UploadFile] = File(default=[]),
    db: Session = Depends(get_db),
):
    """客户提交登记表（有 token 则自动打标签；现有题目全必填，近照可选）"""
    data = RegisterFormData(
        token=token,
        nickname=nickname,
        city=city,
        age=age,
        height=height,
        weight=weight,
        role_self=role_self,
        body_type=body_type,
        income=income,
        job=job,
        lifestyle_status=lifestyle_status,
        hobbies=hobbies,
        current_situation=current_situation,
        expectation=expectation,
        long_distance=long_distance,
    )
    _validate_register_required(data)
    photo_items = await _save_optional_photos(photos, token=data.token)
    photo_urls = [p["url"] for p in photo_items]

    result = {
        "success": True,
        "message": "登记成功，运营人员会尽快联系你",
        "nickname": data.nickname,
        "age": data.age,
        "photo_urls": photo_urls,
        "auto_tagged": False,
    }

    # ── 有 token：专属链接模式，自动打标签 ──
    if data.token:
        link = db.query(RegistrationLink).filter(
            RegistrationLink.token == data.token,
            RegistrationLink.status == "pending",
        ).first()

        if link:
            try:
                # 查找客户 external_userid
                ext_userid = await find_external_userid(
                    link.employee_userid, link.customer_name
                )
                if ext_userid:
                    # 生成标签
                    form_dict = _form_data_dict(data)
                    tag_names = suggest_tags_from_form(form_dict)

                    # 打标签
                    await ensure_tag_group()
                    tag_ids = []
                    for name in tag_names:
                        tag_id = await ensure_tag(name)
                        tag_ids.append(tag_id)
                    await mark_tag(ext_userid, tag_ids, employee_userid=link.employee_userid)

                    result["auto_tagged"] = True
                    result["external_userid"] = ext_userid
                    result["tags_applied"] = tag_names

                    # 标签对员工阅读价值有限；同时直接设置企微客户备注，便于员工在客户列表识别。
                    remark_text = _build_wecom_customer_remark(data)
                    result["wecom_remark"] = remark_text
                    try:
                        remark_pic_mediaid = ""
                        if photo_items:
                            try:
                                remark_pic_mediaid = await upload_wecom_image_media(photo_items[0]["path"])
                                result["remark_pic_uploaded"] = True
                            except Exception as media_exc:
                                result["remark_pic_error"] = str(media_exc)
                        await remark_external_contact(
                            link.employee_userid,
                            ext_userid,
                            remark_text,
                            _build_wecom_customer_description(data),
                            remark_pic_mediaid=remark_pic_mediaid,
                        )
                        result["remark_applied"] = True
                    except Exception as remark_exc:
                        result["remark_error"] = str(remark_exc)
                else:
                    result["tag_warning"] = "客户不在最近客户列表中，需手动补打标签"
            except Exception as e:
                # 打标签失败不阻断表单提交
                result["tag_error"] = str(e)

            # 无论打标签成功与否，链接标记为已使用
            link.status = "used"
            link.used_at = datetime.now(timezone.utc)
            link.submit_result = json.dumps({
                "nickname": data.nickname,
                "city": data.city,
                "age": data.age,
                "role_self": data.role_self,
                "photo_urls": photo_urls,
                "photo_sizes": [p.get("bytes") for p in photo_items],
                "level": evaluate_member_level(_form_data_dict(data)),
                "tags_applied": result.get("tags_applied", []),
                "auto_tagged": result["auto_tagged"],
                "wecom_remark": result.get("wecom_remark"),
                "remark_applied": result.get("remark_applied", False),
                "remark_pic_uploaded": result.get("remark_pic_uploaded", False),
                "remark_pic_error": result.get("remark_pic_error"),
            }, ensure_ascii=False)

            # 保存到会员档案表（同 external_userid 则更新）
            try:
                _save_member_profile(db, data, link, result)
            except Exception:
                pass  # 存档案失败不阻断主流程

            db.commit()

            # ── 通知员工 + 匹配 + 生成客户回复 ──
            try:
                matches = []
                saved_profile = db.query(MemberProfile).filter(
                    MemberProfile.token == link.token
                ).first()
                if saved_profile and saved_profile.nickname:
                    matches = find_matches(db, saved_profile, limit=5)
                    result["matched_count"] = len(matches)

                if link.employee_userid:
                    # 第一条：给员工看的完整填表数据 + 处理建议
                    employee_notice = _format_registration_data_for_employee(data, link, result, matches)
                    await send_text_to_employee(link.employee_userid, employee_notice)

                    # 第二条：只放可直接发给客户的话术，不加任何标题/标签
                    customer_reply = _registration_customer_reply(data)
                    await send_text_to_employee(link.employee_userid, customer_reply)
            except Exception as e:
                result["push_warning"] = str(e)


    return result
