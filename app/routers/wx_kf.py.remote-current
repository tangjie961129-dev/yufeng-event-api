def _ensure_default_playbooks(db: Session) -> None:
    if db.query(CustomerReplyPlaybook).count() > 0:
        return
    for item in DEFAULT_PLAYBOOKS:
        db.add(CustomerReplyPlaybook(source="default", **item))
    db.commit()


def _search_playbooks(db: Session, text: str, limit: int = 5) -> list[CustomerReplyPlaybook]:
    _ensure_default_playbooks(db)
    keywords = [w for w in re.split(r"[\s，。！？,.!?、:：；;]+", text) if len(w) >= 2]
    candidates = db.query(CustomerReplyPlaybook).order_by(CustomerReplyPlaybook.success_count.desc(), CustomerReplyPlaybook.usage_count.desc()).limit(80).all()

    def score(pb: CustomerReplyPlaybook) -> int:
        hay = "\n".join([pb.scenario or "", pb.trigger_keywords or "", pb.recommended_reply or "", pb.style_notes or ""])
        s = 0
        for kw in keywords:
            if kw in hay or kw in (pb.trigger_keywords or ""):
                s += 3
        for token in ["隐私", "真实", "收费", "异地", "资料", "链接", "匹配", "回复", "话术", "填表"]:
            if token in text and token in hay:
                s += 2
        return s

    ranked = sorted(candidates, key=score, reverse=True)
    picked = [p for p in ranked if score(p) > 0][:limit]
    return picked or ranked[: min(limit, len(ranked))]


def _member_context(db: Session, text: str) -> tuple[str, str]:
    name = _extract_named_customer_for_context(text) or ""
    if not name:
        return "", ""
    member = db.query(MemberProfile).filter(MemberProfile.nickname.ilike(f"%{name}%")).order_by(MemberProfile.updated_at.desc()).first()
    if not member:
        return name, f"客户/会员名：{name}\n当前没有查到已提交的会员档案。"
    parts = [
        f"客户/会员：{member.nickname or name}",
        f"城市：{member.city or '未知'}",
        f"年龄：{member.age or '未知'}",
        f"身高体重：{member.height or '未知'}cm / {member.weight or '未知'}kg",
        f"属性：{member.role_self or '未知'}",
        f"体型：{member.body_type or '未知'}",
        f"职业/收入：{member.job or '未知'} / {member.income or '未知'}",
        f"日常状态：{member.lifestyle_status or '无'}",
        f"爱好习惯：{member.hobbies or '无'}",
        f"目前状况：{member.current_situation or '无'}",
        f"期待对象：{member.expectation or '无'}",
        f"短暂异地：{member.long_distance or '未知'}",
    ]
    return name, "\n".join(parts)


