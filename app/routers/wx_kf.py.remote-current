def _clean_learning_text(text: str) -> str:
    """把“记住/以后/这条不错”等学习指令清理成可复用话术。"""
    cleaned = (text or "").strip()
    cleaned = re.sub(r"^(记住|记录|保存|存为|这条不错|以后|下次)[：:，,\s]*", "", cleaned)
    cleaned = re.sub(r"^(客户问[^，。:：]*[，。:：\s]*)", "", cleaned)
    cleaned = cleaned.replace("不要这样说", "避免这样说")
    return cleaned.strip() or text


def _handle_learn(db: Session, text: str, employee_userid: str) -> str:
    scenario = "manual_learning"
    if "隐私" in text or "资料" in text:
        scenario = "privacy_concern"
    elif "收费" in text or "价格" in text:
        scenario = "pricing"
    elif "真实" in text or "骗人" in text or "靠谱" in text:
        scenario = "authenticity"
    elif "油" in text or "虚" in text or "不要" in text or "别" in text or "禁用" in text:
        scenario = "style_guide"

    avoid = ""
    if re.search(r"(不要|别|禁用|太油|太虚)", text):
        avoid = text

    pb = CustomerReplyPlaybook(
        scenario=scenario,
        trigger_keywords=_clean_learning_text(text)[:300],
        recommended_reply=_clean_learning_text(text)[:1500],
        avoid_words=avoid[:500],
        style_notes="来自员工在企微中直接教给助手的经验，后续生成回复时优先参考。",
        source="feedback",
        success_count=1,
    )
    db.add(pb)
    db.commit()
    _save_log(db, employee_userid, text, "learn", reply="已记录", feedback=text)
    return f"✅ 已记录到屿风客服话术库：{scenario}\n沉淀内容：{_clean_learning_text(text)[:80]}\n以后遇到类似问题，我会优先参考这条经验。"


def _format_playbook_context(playbooks: list[CustomerReplyPlaybook]) -> str:
    lines = []
    for i, pb in enumerate(playbooks, 1):
        lines.append(
            f"[{i}] 场景：{pb.scenario}\n关键词：{pb.trigger_keywords}\n推荐说法：{pb.recommended_reply}\n避坑：{pb.avoid_words}\n风格：{pb.style_notes}"
        )
    return "\n\n".join(lines)


async def _query_customer_ai(user_message: str, playbook_context: str, member_context: str = "") -> str | None:
    api_key = getattr(settings, "OPENAI_API_KEY", "") or getattr(settings, "DEEPSEEK_API_KEY", "")
    if not api_key:
        return None
    base_url = (getattr(settings, "OPENAI_BASE_URL", "") or "https://99887123.xyz/v1").rstrip("/")
    model = getattr(settings, "CUSTOMER_ASSISTANT_MODEL", "") or "gpt-5.5"
    system_prompt = f"""你是“屿风回复助手”，服务于屿风男同性恋交友平台的企微员工。
你的任务不是和客户闲聊，而是帮员工生成“可以直接复制发给客户”的专业回复，或给出简短操作建议。

屿风定位：真实、克制、专业、有边界感的男同性恋交友/匹配服务。
回复风格：温暖但不油腻，直接但不生硬，成熟稳重，多说具体理由，少说空泛鸡汤。
禁止风格：不要说“命中注定、灵魂伴侣、缘分注定、亲亲、家人们”；不要承诺百分百、马上脱单、绝对真实。
如果员工是在问“怎么回复客户”，直接给可复制的话术，不要长篇解释。
如果资料不足，明确说“可以先这样回”。

可参考的话术库：
{playbook_context or '暂无'}

相关会员/客户上下文：
{member_context or '暂无'}
"""
    try:
        async with httpx.AsyncClient(timeout=3.0) as client:
            resp = await client.post(
                f"{base_url}/chat/completions",
                headers={"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"},
                json={
                    "model": model,
                    "messages": [
                        {"role": "system", "content": system_prompt},
                        {"role": "user", "content": user_message},
                    ],
                    "max_tokens": 420,
                    "temperature": 0.55,
                },
            )
            if resp.status_code == 200:
                return resp.json()["choices"][0]["message"]["content"].strip()
            print(f"[wx_kf] LLM API {resp.status_code}: {resp.text[:200]}")
    except Exception as exc:
        print(f"[wx_kf] LLM call failed: {type(exc).__name__}: {exc!r}")
    return None


def _fallback_draft(user_message: str, playbooks: list[CustomerReplyPlaybook]) -> str:
    if playbooks:
        p = playbooks[0]
        return f"可以先这样回：\n\n{p.recommended_reply}"
    return "可以先这样回：\n\n理解你的顾虑，我这边会先根据你的情况做基础判断，不会随便把不合适的人硬推给你。你可以先把核心信息发我，我帮你看更适合的方向。"


