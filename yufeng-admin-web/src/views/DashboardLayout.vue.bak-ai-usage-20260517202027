      { label: '引流表单', path: '/lead-forms', icon: Document },
      { label: '引流归因', path: '/lead-attribution', icon: TrendCharts },
      { label: '客服话术库', path: '/ops/scripts', icon: ChatDotRound },
      { label: '朋友圈推送台', path: '/ops/moments', icon: Promotion },
      { label: '指令动作中心', path: '/ops/actions', icon: Operation },
    ],
  },
  {
    title: '小程序业务后台',
    desc: '会员/活动/订单/页面装修/分销',
