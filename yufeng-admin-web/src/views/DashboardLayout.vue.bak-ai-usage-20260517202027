          </div>
        </div>
        <div class="top-actions">
          <span class="admin-name">{{ authStore.user?.display_name || '管理员' }}</span>
          <el-button @click="logout" size="small" round>退出登录</el-button>
        </div>
      </header>
      <main class="content-wrap">
        <router-view />
      </main>
    </div>
  </div>
</template>

