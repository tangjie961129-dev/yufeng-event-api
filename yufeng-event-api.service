[Unit]
Description=屿风活动报名 API
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/yufeng-event-api
EnvironmentFile=/home/ubuntu/yufeng-event-api/.env
ExecStart=/home/ubuntu/yufeng-event-venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
